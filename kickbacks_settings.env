# Kickbacks credentials (מלאו כאן את הפרטים שלכם)
# אם אתם משתמשים באימות Google, השאירו את השדות הרגילים ריקים והכניסו את אסימון Google OAuth (ID token) כאן.
KICKBACKS_USER=YOUR_KICKBACKS_EMAIL
KICKBACKS_PASS=YOUR_KICKBACKS_PASSWORD
# (אופציונלי) אסימון Google OAuth המשמש להתחברות דרך "Sign in with Google"
KICKBACKS_GOOGLE_IDTOKEN=YOUR_GOOGLE_ID_TOKEN
